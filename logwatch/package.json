{
  "name": "logwatch",
  "version": "1.0.0",
  "description": "LogWatch — real-time stdout viewer",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder",
    "preview": "electron ."
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
"build": {
  "appId": "com.logwatch.app",
  "productName": "LogWatch",
  "directories": { "output": "dist-electron" },
  "win": {
    "target": "nsis",
    "signAndEditExecutable": false
  },
  "mac": { "target": "dmg" },
  "linux": { "target": "AppImage" }
}
}